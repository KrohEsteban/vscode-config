{
  // --- Editor ---
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.smoothScrolling": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  "editor.rulers": [120, 140],
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },

  // --- Files ---
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": false,

  // --- Java (navigation + errors only, no local execution) ---
  "java.server.launchMode": "Standard",
  "java.test.defaultConfig": "",
  "java.compile.nullAnalysis.mode": "disabled",
  "java.debug.settings.enableRunDebugCodeLens": false,
  "java.test.editor.enableShortcuts": false,
  "java.inlayHints.parameterNames.enabled": "literals",
  "java.project.importOnFirstTimeStartup": "disabled",

  // --- Go (navigation + errors only) ---
  "go.testOnSave": false,
  "go.buildOnSave": "off",
  "go.vetOnSave": "off",
  "go.coverOnSave": false,
  "go.addTags": { "tags": "json", "options": "json=omitempty" },

  // --- Spell checking (CSpell) ---
  "cSpell.enabled": true,
  "cSpell.language": "en",

  // --- ESLint ---
  "eslint.enable": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // --- Prettier ---
  "prettier.enable": true,

  // --- Tailwind ---
  "tailwindCSS.validate": true,

  // --- Window ---
  "window.commandCenter": true,

  // --- Misc ---
  "makefile.configureOnOpen": false
}
