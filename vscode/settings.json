{
  // --- Neovim integration ---
  "vscode-neovim.neovimInitVimPaths.linux": "~/.config/nvim/init.lua",
  "vscode-neovim.neovimExecutablePaths.linux": "nvim",
  "vscode-neovim.useCtrlKeys": true,
  "vscode-neovim.useCtrlKeysInsertMode": false,
  "vscode-neovim.useWsl": false,
  "vscode-neovim.neovimUseFork": true,
  "vscode-neovim.highlightGroups.highlights": {
    "Normal": { "background": null },
    "Cursor": { "background": null }
  },
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },

  // --- Editor ---
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.smoothScrolling": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  "editor.rulers": [120, 140],
  "editor.wordBasedSuggestions": "off",
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },

  // --- Files ---
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": false,

  // --- Window ---
  "window.commandCenter": true,

  // --- Misc ---
  "makefile.configureOnOpen": false
}
